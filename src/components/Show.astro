---
const vimeoId = '487104769';
---

<section id="show" class="py-24 px-4 bg-zinc-900">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-display text-4xl md:text-5xl text-amber-400 mb-4">Show Completo</h2>
    <p class="text-zinc-400 mb-10 text-lg">Assista ao espetáculo na íntegra</p>

    <div class="relative w-full rounded-2xl overflow-hidden" style="padding-top: 56.25%;">
      <iframe
        src={`https://player.vimeo.com/video/${vimeoId}?color=f59e0b&title=0&byline=0&portrait=0`}
        class="absolute inset-0 w-full h-full"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title="Juh Vieira – Terreno Baldio – Show Completo"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>
